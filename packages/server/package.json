{
  "name": "@notifyd/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./router": {
      "import": "./dist/router.js",
      "types": "./dist/router.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@notifyd/shared": "workspace:*",
    "@trpc/server": "^11.1",
    "ajv": "^8.18.0",
    "fastify": "^5.2",
    "zod": "^3.24"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19",
    "typescript": "^5.7"
  }
}